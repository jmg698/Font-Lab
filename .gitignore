# Dependencies / build output
node_modules/
.next/

# M0 spike: keep the JSON evidence, ignore heavy/regenerable artifacts
spike/m0/out/*.png
spike/m0/out/*.log
spike/m0/out/*.pid

# M1: keep JSON evidence, ignore logs/images; the pick output is a runtime artifact
cli/out/*.log
cli/out/*.png
examples/sample-next-site/.font-lab/
examples/clean-next-site/.font-lab/

# Generated parity fonts staged by the pipelines (regenerated by run scripts)
examples/sample-next-site/public/fontlab/

# Packaging: skill bundled into the CLI package by `prepack` (source of truth is /skill)
cli/skill/

# Misc
.DS_Store
*.tsbuildinfo
